# 复制为 .env.local 后填入你的 key；重启 dev server 生效。
# ⚠️ VITE_ 前缀的值在浏览器可见，仅 dev / 内部体验。生产请走后端中转。

# === 可灵 Kling（图生视频主力） ===
# https://app.klingai.com → 右上角头像 → 账户 → API 访问 → 创建 AK+SK
VITE_KLING_AK=xxxxxxxxxxxxxxxxxxxxxxxx
VITE_KLING_SK=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_KLING_MODEL=kling-v2-1-master
VITE_KLING_MODE=pro
VITE_KLING_DURATION=5
VITE_KLING_RATIO=9:16

# === 火山方舟（豆包 LLM 写文案） ===
# https://console.volcengine.com/ark → API Key 管理
VITE_ARK_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_ARK_LLM_MODEL=doubao-1-5-pro-32k-250115

# === 火山豆包 TTS（配音，可选） ===
# https://console.volcengine.com/speech/service
VITE_TTS_APP_ID=
VITE_TTS_ACCESS_TOKEN=
VITE_TTS_VOICE=BV705_streaming
