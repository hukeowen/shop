# 复制为 .env.local 后按需填入；重启 dev server 生效。
#
# Phase 0.2 起，所有第三方 AI key 全部收归后端（BFF 通过 JWT 鉴权）。
# 浏览器 bundle 不应再出现 VITE_ARK_API_KEY / VITE_JIMENG_* / VITE_TTS_ACCESS_TOKEN。
#
# 下面带注释的变量分两类：
#   · VITE_* 前缀 = 会打进浏览器 bundle；只放「非敏感配置项」。
#   · 无前缀     = 仅 Node 侧车（vite.config.js）读取，不会泄露。

# === 前端 AI 配置项（可打包进 bundle；不敏感） ===
VITE_ARK_LLM_MODEL=doubao-1-5-pro-32k-250115
VITE_ARK_VISION_MODEL=doubao-1-5-vision-pro-32k-250115
VITE_ARK_VIDEO_MODEL=doubao-seedance-1-5-pro-251215
VITE_VIDEO_RESOLUTION=1080p
VITE_VIDEO_DURATION=10
VITE_VIDEO_RATIO=9:16
VITE_VIDEO_SCENES=3
VITE_TTS_PROVIDER=volc
VITE_TTS_VOICE=zh_male_beijingxiaoye_emo_v2_mars_bigtts

# === 服务端 Sidecar 用（只给 vite.config.js 本地开发时用，不会打进 bundle） ===
# 即梦AI 签名（若本地需要用 sidecar /jimeng 离线回归，才需要填；
# 正式链路已经走后端 BFF /app-api/merchant/mini/ai-video/bff/jimeng/*）
JIMENG_AK=
JIMENG_SK=

# 火山 TOS（sidecar /oss/upload、/video/mux、/video/endcard 用）
TOS_AK=
TOS_SK=
TOS_BUCKET=tanxiaoer
TOS_REGION=cn-beijing

# 火山 openspeech TTS（sidecar /video/mux、/video/endcard 内部合片用）
TTS_ACCESS_TOKEN=
TTS_RESOURCE_ID=volc.service_type.10029

# 抖音开放平台（sidecar /douyin/* 发布流程用）
# OAuth 回调需要在抖音开放平台「网页应用」把 http://localhost:5180/douyin/oauth-callback 登记
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
