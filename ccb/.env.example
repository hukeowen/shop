# 摊小二部署配置模板
# 使用方法：cp .env.example .env  然后把下面的占位值改成真实密码
# ⚠️ .env 包含敏感凭据，切勿提交到 Git（已加入 .gitignore）

# ── 必填：数据库 ─────────────────────────────────────────────────────────────
MYSQL_ROOT_PASS=CHANGE_ME_strong_mysql_root_password
DB_PASS=CHANGE_ME_strong_app_db_password

# ── 必填：Redis ──────────────────────────────────────────────────────────────
REDIS_PASS=CHANGE_ME_strong_redis_password

# ── 必填：商户 ↔ 视频模块内部鉴权 token（≥16 字符） ─────────────────────────
MERCHANT_INTERNAL_TOKEN=CHANGE_ME_at_least_16_chars_random

# =============================================================================
# AI 视频相关密钥（共 7 个）
#
#   后端 yudao-module-video/src/main/resources/application-video.yaml 直接读这些 env。
#   Phase 0.2 起明文 KEY 不再进前端 bundle，全部走后端 BFF（JWT 鉴权）。
#
#   ⚠️ 演示当天可全部留空 — 缺则 AI 视频生成 / 抖音发布链路不可用，
#      但「商户开通 / 商品上架 / 推广引擎 / 用户下单 / 双端订单」都不受影响。
# =============================================================================

# ── 火山方舟 Ark：LLM（文案生成）+ Seedance（图生视频） ─ ★最重要 ─────────────
# 控制台：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# 缺则：AI 视频「创建任务 / 一键生成文案」步骤报 ARK_CHAT_FAILED
ARK_API_KEY=

# ── 火山豆包 TTS（配音）─────────────────────────────────────────────────────
# 控制台：https://console.volcengine.com/speech/app（应用列表 → AppID + AccessToken）
# 缺则：视频成片无 AI 配音
VOLCANO_APP_ID=
VOLCANO_ACCESS_TOKEN=

# ── 即梦 AI 图生视频（目前商户端主路径，前端调 BFF /jimeng/submit） ──────────
# 控制台：https://console.volcengine.com/iam/keymanage（火山引擎 → 访问密钥）
# 缺则：商户上架商品时"AI 一键生成视频"按钮不可用
JIMENG_AK=
JIMENG_SK=

# ── 老火山智能创作接口（保留兼容；主链路已切 Seedance，可留空） ────────────
# 同样在 https://console.volcengine.com/iam/keymanage 拿 AK/SK
VOLCANO_AK=
VOLCANO_SK=

# ── 抖音开放平台（视频发布）────────────────────────────────────────────────
# 控制台：https://open.douyin.com/platform/app/list（应用 → ClientKey + ClientSecret）
# 演示当天若没真实抖音账号，可只演示"AI 视频生成 + 文案确认"，不发布
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=

# ── HTTPS 证书（Let's Encrypt 免费，certbot 自动签 + 续期） ─────────────────
# 必须先把域名 DNS 指向本机公网 IP + 80 端口公网可达。
# deploy.sh 会用 webroot 模式签 + 装 cron 每天 03:00 自动续期。
SERVER_NAME=www.doupaidoudian.com
LE_EMAIL=admin@doupaidoudian.com

# ── 通联收付通：H5 收银台 + 商户进件 ───────────────────────────────────────
# 用户为「平台 AI 视频套餐」付款时走通联 H5 收银台。
# 文档：https://prodoc.allinpay.com/doc/256/
# 测试参数：docs/测试参数.txt
ALLINPAY_ENABLED=true
# 沙箱 https://test-vsp.allinpay.com / 生产 https://vsp.allinpay.com
ALLINPAY_API_BASE_URL=https://test-vsp.allinpay.com
# H5 收银台 appid（通联给的 8 位数字）
ALLINPAY_APPID=00240592
# 商户号
ALLINPAY_MERCHANT_NO=56165105331VE5Z
# MD5 密钥（异步通知验签用）
ALLINPAY_MD5_KEY=allinpay123
# 签名类型：RSA 或 SM2 — 必须跟通联控制台为该 cusid 配的一致
# 默认 RSA。如果通联给的 docs/测试参数.txt 同时给 RSA 和 SM2，两套都填进来，签名走哪个由 SIGN_TYPE 决定。
ALLINPAY_SIGN_TYPE=SM2
# RSA 私钥（PKCS8 PEM base64 内容；单行；不带 BEGIN/END 头）— signType=RSA 时使用
ALLINPAY_RSA_PRIVATE_KEY=
# RSA 公钥 — 异步通知验签
ALLINPAY_RSA_PUBLIC_KEY=
# SM2 私钥（PKCS8 PEM base64 内容；单行）— signType=SM2 时使用
ALLINPAY_SM2_PRIVATE_KEY=
# 通联 SM2 公钥（X509 PEM）— 异步通知验签
ALLINPAY_SM2_PUBLIC_KEY=
# 商户进件用的 orgId（如未走商户进件可留空）
ALLINPAY_ORG_ID=
# 是否启用聚合收银台 onepay（true=用户在通联页选 微信/支付宝/云闪付/快捷）
# 默认 false 走 unionorder（按浏览器 UA 推单一通道）
# 切 true 前必须先在通联控制台开通 onepay 产品权限，否则通联返"api 角色权限不足"
ALLINPAY_USE_ONEPAY=false

# ── SMS 短信验证码 ──────────────────────────────────────────────────────────
# YUDAO_SMS_DEMO_MODE=true 时全场景固定验证码（演示模式，无需短信网关）。
# 生产上线前请改 false，并在 PC 后台「系统管理 → 短信渠道」配真实网关
#   （阿里云/腾讯云/华为云）+「短信模板」绑 user-sms-login 模板（变量 {code}）。
# demo-mode=false 但短信网关未配 → 前端发码会失败。
YUDAO_SMS_DEMO_MODE=true
YUDAO_SMS_DEMO_CODE=888888

# ── 可选：GitHub 访问加速（国内阿里云强烈建议开启） ─────────────────────────
# 国内访问 github.com 常被限速/超时；通过下面任一反代拉取，速度 10+ MB/s
# 已实测可用（任选其一）：
#   https://gh-proxy.com/
#   https://ghfast.top/
#   https://gh.llkk.cc/
# GITHUB_PROXY=https://gh-proxy.com/

# ── 可选：非敏感配置覆写 ─────────────────────────────────────────────────────
# REPO_URL=https://github.com/hukeowen/shop.git
# BRANCH=main
# ROOT_DIR=/opt/tanxiaer
# SERVER_NAME=tanxiaer.example.com   # 建议改成真实域名
# DB_NAME=ruoyi-vue-pro
# DB_USER=tanxiaer
# REDIS_PORT=6379
# SERVER_PORT=48080
# SERVICE_USER=tanxiaer
# MAVEN_VERSION=3.9.15
# NODE_VERSION=16
